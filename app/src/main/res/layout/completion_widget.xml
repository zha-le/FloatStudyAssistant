<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#40000000"
    android:alpha="0.6"
    android:focusable="true">

    <!--  标题栏  -->
    <LinearLayout
        android:id="@+id/title_bar"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#80000000"
        android:padding="8dp">

        <TextView
            android:id="@+id/title_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="16dp"
            android:text="qwen-turbo-0919"
            android:textColor="@color/white"/>

    </LinearLayout>

    <!--  内容   -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:padding="8dp"
        android:scrollbarThumbVertical="@android:color/darker_gray">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/userPrompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="true"
                android:padding="4dp"
                android:textIsSelectable="true"
                android:text="User Prompt"
                android:visibility="gone"
                android:textColor="#00C800"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/thinkOutput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="true"
                android:padding="4dp"
                android:textIsSelectable="true"
                android:text="Chain of thinking"
                android:visibility="gone"
                android:textColor="#909090"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/contentOutput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="true"
                android:padding="4dp"
                android:textIsSelectable="true"
                android:text="How can I help you today?"
                android:textColor="@color/white"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/errorOutput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="true"
                android:padding="4dp"
                android:textIsSelectable="true"
                android:text="Error Output"
                android:visibility="gone"
                android:textColor="#FFC107"
                android:textSize="16sp" />

        </LinearLayout>

    </ScrollView>

    <!-- 输入框 -->
    <EditText
        android:id="@+id/contentInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="72dp"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:hint="Enter..."
        android:inputType="textMultiLine"
        android:scrollbars="vertical"
        android:textColor="@android:color/white"
        android:textColorHint="#55FFFFFF"
        android:padding="8dp"
        android:alpha="1"
        android:singleLine="true"/>

    <!--  按钮  -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/close_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#80000000"
            android:layout_marginRight="4dp"
            android:textColor="#FFFFFFFF"
            android:text="关闭"/>

        <Button
            android:id="@+id/submit_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#80000000"
            android:layout_marginHorizontal="4dp"
            android:textColor="#FFFFFFFF"
            android:text="发送"/>

        <Button
            android:id="@+id/stop_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#80000000"
            android:layout_marginHorizontal="4dp"
            android:textColor="#FFFFFFFF"
            android:visibility="gone"
            android:text="停止"/>

        <Button
            android:id="@+id/copy_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#80000000"
            android:layout_marginLeft="4dp"
            android:textColor="#FFFFFFFF"
            android:text="复制"/>

    </LinearLayout>

</LinearLayout>